# Archivo de variables de entorno para TiktokDownloaderPython
# Copia este archivo como .env y completa los valores necesarios

# Directorio raíz de descargas (opcional, por defecto: ./downloads)
DOWNLOADS_ROOT=./downloads

# Configuración de concurrencia y limpieza
MAX_CONCURRENT_TASKS=3
EXPIRATION_SECONDS=86400
CLEANUP_INTERVAL=10

# Configuración de RabbitMQ
RABBIT_HOST=localhost
QUEUE_TASKS=tiktok_tasks
QUEUE_RESULTS=tiktok_results

# Configuración de Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Modo producción
IS_PRODUCTION=False
